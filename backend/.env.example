NODE_ENV=production
PORT=4000
CORS_ORIGIN=http://localhost:5173,https://pethubvn.store,https://www.pethubvn.store

# PostgreSQL (Oracle VPS)
DATABASE_URL=postgresql://pethub:replace_me@postgres:5432/pethub?schema=public

# Redis / BullMQ
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=replace_me

# Auth
AUTH_MOCK_ENABLED=false
DEFAULT_SENSITIVE_PASSWORD=replace-with-strong-password-12-plus

# Firebase Admin (choose ONE style below)
FIREBASE_SERVICE_ACCOUNT_PATH=
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# AI
GEMINI_API_KEY=
AI_CHAT_ENABLED=false
GEMINI_CHAT_MODEL=gemini-2.5-flash
AI_CHAT_MAX_OUTPUT_TOKENS=260
AI_CHAT_HISTORY_TURNS=6

# Payments (reserved for payOS integration in next phase)
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=
PAYOS_RETURN_URL=https://pethubvn.store/manager/pos?payment=success
PAYOS_CANCEL_URL=https://pethubvn.store/manager/pos?payment=cancel
FRONTEND_URL=https://pethubvn.store
PAYOS_BACKGROUND_SYNC_ENABLED=true

# Email / reminders
RESEND_API_KEY=
RESEND_FROM=booking@pethubvn.store
RESEND_FROM_EMAIL=booking@pethubvn.store
REMINDER_SCHEDULER_ENABLED=true
