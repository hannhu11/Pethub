NODE_ENV=production
PORT=4000
CORS_ORIGIN=https://app.example.com

# PostgreSQL (Oracle VPS)
DATABASE_URL=postgresql://pethub:replace_me@postgres:5432/pethub?schema=public

# Redis / BullMQ
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=replace_me

# Auth
AUTH_MOCK_ENABLED=false
DEFAULT_SENSITIVE_PASSWORD=admin12345

# Firebase Admin (choose ONE style below)
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# AI
GEMINI_API_KEY=

# Payments (reserved for payOS integration in next phase)
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=
