generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  customer
  manager
}

enum AppointmentStatus {
  pending
  confirmed
  completed
  cancelled
}

enum PaymentStatus {
  unpaid
  paid
  refunded
}

enum ReminderStatus {
  scheduled
  sent
  failed
  cancelled
}

enum CustomerSegment {
  vip
  loyal
  regular
  new
}

enum PaymentMethod {
  cash
  transfer
  card
  payos
  momo
  zalopay
}

enum InvoiceItemType {
  service
  product
}

enum NotificationTarget {
  customer
  manager
  all
}

enum ReminderChannel {
  email
  sms
}

model Clinic {
  id                String             @id @default(cuid())
  slug              String             @unique
  name              String
  phone             String?
  address           String?
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  users             User[]
  customers         Customer[]
  pets              Pet[]
  services          Service[]
  products          Product[]
  appointments      Appointment[]
  invoices          Invoice[]
  notifications     Notification[]
  reminders         Reminder[]
  reminderTemplates ReminderTemplate[]
  clinicSettings    ClinicSettings[]
  notificationSettings NotificationSettings?
  subscriptions     Subscription[]
  paymentTxns       PaymentTransaction[]
  medicalRecords    MedicalRecord[]
  digitalCardEvents DigitalCardEvent[]
  auditLogs         AuditLog[]
}

model User {
  id                 String          @id @default(cuid())
  clinicId           String
  firebaseUid        String          @unique
  role               Role
  name               String
  phone              String
  email              String
  passwordHash       String?
  isActive           Boolean         @default(true)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  clinic             Clinic          @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  customerProfile    Customer?
  managedAppointments Appointment[]  @relation("ManagedAppointments")
  managedInvoices    Invoice[]       @relation("ManagedInvoices")
  notifications      Notification[]
  auditLogs          AuditLog[]      @relation("AuditLogActor")
  clinicSettingsEdits ClinicSettings[] @relation("ClinicSettingsUpdatedBy")
  createdMedicalRecords MedicalRecord[] @relation("MedicalRecordCreatedBy")
  digitalCardEvents  DigitalCardEvent[] @relation("DigitalCardEventActor")

  @@unique([clinicId, email])
  @@index([clinicId, role])
}

model ClinicSettings {
  id          String   @id @default(cuid())
  clinicId    String   @unique
  clinicName  String
  taxId       String?
  phone       String
  address     String
  invoiceNote String?
  timezone    String   @default("Asia/Ho_Chi_Minh")
  updatedById String?
  updatedBy   User?    @relation("ClinicSettingsUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  clinic      Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model NotificationSettings {
  id            String   @id @default(cuid())
  clinicId      String   @unique
  emailBooking  Boolean  @default(true)
  emailReminder Boolean  @default(true)
  smsBooking    Boolean  @default(false)
  smsReminder   Boolean  @default(true)
  dailyReport   Boolean  @default(true)
  weeklyReport  Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  clinic        Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
}

model Customer {
  id            String          @id @default(cuid())
  clinicId      String
  userId        String?         @unique
  name          String
  phone         String
  email         String?
  segment       CustomerSegment @default(new)
  totalSpent    Decimal         @default(0) @db.Decimal(14, 2)
  totalVisits   Int             @default(0)
  lastVisitAt   DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  clinic        Clinic          @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  user          User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  pets          Pet[]
  appointments  Appointment[]
  invoices      Invoice[]
  reminders     Reminder[]
  notifications Notification[]
  medicalRecords MedicalRecord[]

  @@index([clinicId, segment])
  @@index([clinicId, phone])
  @@index([clinicId, totalSpent])
  @@index([clinicId, createdAt])
}

model Pet {
  id            String   @id @default(cuid())
  clinicId      String
  customerId    String
  imageUrl      String?
  name          String
  species       String
  breed         String?
  gender        String?
  dateOfBirth   DateTime?
  weightKg      Decimal? @db.Decimal(5, 2)
  coatColor     String?
  bloodType     String?
  neutered      String? // yes | no | none
  microchipId   String?
  specialNotes  String?  @db.VarChar(55)
  lastCheckupAt DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  clinic        Clinic           @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  customer      Customer         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  appointments  Appointment[]
  reminders     Reminder[]
  invoiceItems  InvoiceLineItem[]
  medicalRecords MedicalRecord[]
  digitalCardEvents DigitalCardEvent[]

  @@index([clinicId, customerId])
  @@index([clinicId, name])
}

model Service {
  id           String   @id @default(cuid())
  clinicId     String
  code         String
  name         String
  description  String?
  durationMin  Int
  price        Decimal  @db.Decimal(12, 2)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  clinic       Clinic           @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  appointments Appointment[]
  invoiceItems InvoiceLineItem[]

  @@unique([clinicId, code])
  @@index([clinicId, name])
}

model Product {
  id           String   @id @default(cuid())
  clinicId     String
  sku          String
  name         String
  category     String?
  description  String?
  price        Decimal  @db.Decimal(12, 2)
  stock        Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  clinic       Clinic           @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  invoiceItems InvoiceLineItem[]

  @@unique([clinicId, sku])
  @@index([clinicId, name])
  @@index([clinicId, category])
}

model Appointment {
  id             String            @id @default(cuid())
  clinicId       String
  customerId     String
  petId          String
  serviceId      String
  managerId      String?
  appointmentAt  DateTime
  note           String?
  status         AppointmentStatus @default(pending)
  paymentStatus  PaymentStatus     @default(unpaid)
  paidAt         DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  clinic         Clinic            @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  customer       Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  pet            Pet               @relation(fields: [petId], references: [id], onDelete: Cascade)
  service        Service           @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  manager        User?             @relation("ManagedAppointments", fields: [managerId], references: [id], onDelete: SetNull)
  invoice        Invoice?
  medicalRecord  MedicalRecord?

  @@index([clinicId, appointmentAt, status])
  @@index([clinicId, customerId, appointmentAt])
  @@index([clinicId, petId, appointmentAt])
  @@unique([clinicId, petId, appointmentAt])
}

model Invoice {
  id             String        @id @default(cuid())
  clinicId       String
  invoiceNo      String        @unique
  appointmentId  String?       @unique
  customerId     String
  managerId      String?
  paymentMethod  PaymentMethod
  paymentStatus  PaymentStatus @default(paid)
  subtotal       Decimal       @db.Decimal(14, 2)
  taxPercent     Decimal       @default(8) @db.Decimal(5, 2)
  taxAmount      Decimal       @db.Decimal(14, 2)
  grandTotal     Decimal       @db.Decimal(14, 2)
  issuedAt       DateTime      @default(now())
  immutableHash  String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  clinic         Clinic        @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  appointment    Appointment?  @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  customer       Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  manager        User?         @relation("ManagedInvoices", fields: [managerId], references: [id], onDelete: SetNull)
  items          InvoiceLineItem[]
  paymentTxns    PaymentTransaction[]

  @@index([clinicId, customerId, issuedAt])
}

model InvoiceLineItem {
  id          String          @id @default(cuid())
  invoiceId   String
  itemType    InvoiceItemType
  serviceId   String?
  productId   String?
  petId       String?
  name        String
  qty         Int             @default(1)
  unitPrice   Decimal         @db.Decimal(12, 2)
  total       Decimal         @db.Decimal(14, 2)
  createdAt   DateTime        @default(now())

  invoice     Invoice         @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  service     Service?        @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  product     Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  pet         Pet?            @relation(fields: [petId], references: [id], onDelete: SetNull)

  @@index([invoiceId])
  @@index([itemType])
}

model Notification {
  id          String             @id @default(cuid())
  clinicId    String
  userId      String?
  customerId  String?
  target      NotificationTarget @default(manager)
  title       String
  body        String
  linkTo      String?
  read        Boolean            @default(false)
  readAt      DateTime?
  createdAt   DateTime           @default(now())

  clinic      Clinic             @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  user        User?              @relation(fields: [userId], references: [id], onDelete: Cascade)
  customer    Customer?          @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([clinicId, userId, read, createdAt])
  @@index([clinicId, customerId, read, createdAt])
}

model Reminder {
  id            String          @id @default(cuid())
  clinicId      String
  customerId    String
  petId         String
  channel       ReminderChannel
  templateName  String?
  message       String
  scheduledAt   DateTime?
  sentAt        DateTime?
  failedReason  String?
  status        ReminderStatus  @default(scheduled)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  clinic        Clinic          @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  customer      Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  pet           Pet             @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@index([clinicId, status, scheduledAt])
  @@index([clinicId, customerId, status])
}

model ReminderTemplate {
  id               String   @id @default(cuid())
  clinicId         String
  name             String
  type             String
  channelDefaults  String[]
  messageTemplate  String
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  clinic           Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@unique([clinicId, name])
}

model Subscription {
  id                String   @id @default(cuid())
  clinicId          String   @unique
  planCode          String
  planName          String
  amount            Decimal  @db.Decimal(12, 2)
  currency          String   @default("VND")
  isActive          Boolean  @default(false)
  startedAt         DateTime?
  expiresAt         DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  clinic            Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
}

model PaymentTransaction {
  id               String        @id @default(cuid())
  clinicId         String
  invoiceId        String?
  provider         String
  providerRef      String?       @unique
  paymentMethod    PaymentMethod
  amount           Decimal       @db.Decimal(14, 2)
  currency         String        @default("VND")
  status           PaymentStatus @default(unpaid)
  metadata         Json?
  paidAt           DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  clinic           Clinic        @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  invoice          Invoice?      @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([clinicId, provider, status])
  @@index([clinicId, createdAt])
}

model MedicalRecord {
  id            String    @id @default(cuid())
  clinicId      String
  petId         String
  customerId    String
  appointmentId String?   @unique
  doctorName    String?
  diagnosis     String
  treatment     String
  notes         String?
  nextVisitAt   DateTime?
  recordedAt    DateTime  @default(now())
  createdById   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  clinic        Clinic      @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  pet           Pet         @relation(fields: [petId], references: [id], onDelete: Cascade)
  customer      Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  appointment   Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  createdBy     User?       @relation("MedicalRecordCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([clinicId, petId, recordedAt])
  @@index([clinicId, customerId, recordedAt])
}

model DigitalCardEvent {
  id          String   @id @default(cuid())
  clinicId    String
  petId       String
  actorId     String?
  action      String
  note        String?
  createdAt   DateTime @default(now())

  clinic      Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  pet         Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
  actor       User?    @relation("DigitalCardEventActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([clinicId, petId, createdAt])
}

model AuditLog {
  id          String   @id @default(cuid())
  clinicId    String?
  actorId     String?
  action      String
  entityType  String
  entityId    String?
  before      Json?
  after       Json?
  ipAddress   String?
  createdAt   DateTime @default(now())

  clinic      Clinic?  @relation(fields: [clinicId], references: [id], onDelete: SetNull)
  actor       User?    @relation("AuditLogActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([clinicId, entityType, entityId])
  @@index([clinicId, createdAt])
}
