generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  customer
  manager
}

enum AppointmentStatus {
  pending
  confirmed
  completed
  cancelled
}

enum PaymentStatus {
  unpaid
  paid
  refunded
}

enum ReminderStatus {
  scheduled
  sent
  failed
  cancelled
}

enum CustomerSegment {
  vip
  loyal
  regular
  new
}

enum PaymentMethod {
  cash
  transfer
  card
  payos
  momo
  zalopay
}

enum InvoiceItemType {
  service
  product
}

enum NotificationTarget {
  customer
  manager
  all
}

enum ReminderChannel {
  email
  sms
}

model User {
  id            String    @id @default(cuid())
  firebaseUid   String    @unique
  role          Role
  name          String
  phone         String
  email         String    @unique
  passwordHash  String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  customerProfile      Customer?
  managedAppointments  Appointment[]  @relation("ManagedAppointments")
  managedInvoices      Invoice[]      @relation("ManagedInvoices")
  notifications        Notification[]
  auditLogs            AuditLog[]
  clinicSettingsEdits  ClinicSettings[] @relation("ClinicSettingsUpdatedBy")
}

model ClinicSettings {
  id          String   @id @default(cuid())
  clinicName  String
  taxId       String?
  phone       String
  address     String
  invoiceNote String?
  timezone    String   @default("Asia/Ho_Chi_Minh")
  updatedById String?
  updatedBy   User?    @relation("ClinicSettingsUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Customer {
  id            String          @id @default(cuid())
  userId        String?         @unique
  name          String
  phone         String
  email         String?
  segment       CustomerSegment @default(new)
  totalSpent    Decimal         @default(0) @db.Decimal(14, 2)
  totalVisits   Int             @default(0)
  lastVisitAt   DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  user          User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  pets          Pet[]
  appointments  Appointment[]
  invoices      Invoice[]
  reminders     Reminder[]
  notifications Notification[]

  @@index([segment])
  @@index([phone])
  @@index([totalSpent])
}

model Pet {
  id            String   @id @default(cuid())
  customerId    String
  imageUrl      String?
  name          String
  species       String
  breed         String?
  gender        String?
  dateOfBirth   DateTime?
  weightKg      Decimal? @db.Decimal(5, 2)
  coatColor     String?
  bloodType     String?
  neutered      String? // yes | no | none
  microchipId   String?
  specialNotes  String?  @db.VarChar(55)
  lastCheckupAt DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  customer      Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  appointments  Appointment[]
  reminders     Reminder[]
  invoiceItems  InvoiceLineItem[]

  @@index([customerId])
  @@index([name])
}

model Service {
  id           String   @id @default(cuid())
  code         String   @unique
  name         String
  description  String?
  durationMin  Int
  price        Decimal  @db.Decimal(12, 2)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  appointments Appointment[]
  invoiceItems InvoiceLineItem[]

  @@index([name])
}

model Product {
  id           String   @id @default(cuid())
  sku          String   @unique
  name         String
  category     String?
  description  String?
  price        Decimal  @db.Decimal(12, 2)
  stock        Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  invoiceItems InvoiceLineItem[]

  @@index([name])
  @@index([category])
}

model Appointment {
  id             String            @id @default(cuid())
  customerId     String
  petId          String
  serviceId      String
  managerId      String?
  appointmentAt  DateTime
  note           String?
  status         AppointmentStatus @default(pending)
  paymentStatus  PaymentStatus     @default(unpaid)
  paidAt         DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  customer       Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  pet            Pet               @relation(fields: [petId], references: [id], onDelete: Cascade)
  service        Service           @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  manager        User?             @relation("ManagedAppointments", fields: [managerId], references: [id], onDelete: SetNull)
  invoice        Invoice?

  @@index([appointmentAt, status])
  @@index([customerId, appointmentAt])
  @@index([petId, appointmentAt])
  @@unique([petId, appointmentAt])
}

model Invoice {
  id             String        @id @default(cuid())
  invoiceNo      String        @unique
  appointmentId  String?       @unique
  customerId     String
  managerId      String?
  paymentMethod  PaymentMethod
  paymentStatus  PaymentStatus @default(paid)
  subtotal       Decimal       @db.Decimal(14, 2)
  taxPercent     Decimal       @default(8) @db.Decimal(5, 2)
  taxAmount      Decimal       @db.Decimal(14, 2)
  grandTotal     Decimal       @db.Decimal(14, 2)
  issuedAt       DateTime      @default(now())
  immutableHash  String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  appointment    Appointment?  @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  customer       Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  manager        User?         @relation("ManagedInvoices", fields: [managerId], references: [id], onDelete: SetNull)
  items          InvoiceLineItem[]
  paymentTxns    PaymentTransaction[]

  @@index([customerId, issuedAt])
}

model InvoiceLineItem {
  id          String          @id @default(cuid())
  invoiceId   String
  itemType    InvoiceItemType
  serviceId   String?
  productId   String?
  petId       String?
  name        String
  qty         Int             @default(1)
  unitPrice   Decimal         @db.Decimal(12, 2)
  total       Decimal         @db.Decimal(14, 2)
  createdAt   DateTime        @default(now())

  invoice     Invoice         @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  service     Service?        @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  product     Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  pet         Pet?            @relation(fields: [petId], references: [id], onDelete: SetNull)

  @@index([invoiceId])
  @@index([itemType])
}

model Notification {
  id          String             @id @default(cuid())
  userId      String?
  customerId  String?
  target      NotificationTarget @default(manager)
  title       String
  body        String
  linkTo      String?
  read        Boolean            @default(false)
  readAt      DateTime?
  createdAt   DateTime           @default(now())

  user        User?              @relation(fields: [userId], references: [id], onDelete: Cascade)
  customer    Customer?          @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([userId, read, createdAt])
  @@index([customerId, read, createdAt])
}

model Reminder {
  id            String          @id @default(cuid())
  customerId    String
  petId         String
  channel       ReminderChannel
  templateName  String?
  message       String
  scheduledAt   DateTime?
  sentAt        DateTime?
  failedReason  String?
  status        ReminderStatus  @default(scheduled)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  customer      Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  pet           Pet             @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@index([status, scheduledAt])
  @@index([customerId, status])
}

model ReminderTemplate {
  id               String   @id @default(cuid())
  name             String   @unique
  type             String
  channelDefaults  String[]
  messageTemplate  String
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Subscription {
  id                String   @id @default(cuid())
  clinicId          String   @unique
  planCode          String
  planName          String
  amount            Decimal  @db.Decimal(12, 2)
  currency          String   @default("VND")
  isActive          Boolean  @default(false)
  startedAt         DateTime?
  expiresAt         DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model PaymentTransaction {
  id               String        @id @default(cuid())
  invoiceId        String?
  provider         String
  providerRef      String?       @unique
  paymentMethod    PaymentMethod
  amount           Decimal       @db.Decimal(14, 2)
  currency         String        @default("VND")
  status           PaymentStatus @default(unpaid)
  metadata         Json?
  paidAt           DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  invoice          Invoice?      @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([provider, status])
  @@index([createdAt])
}

model AuditLog {
  id          String   @id @default(cuid())
  actorId     String?
  action      String
  entityType  String
  entityId    String?
  before      Json?
  after       Json?
  ipAddress   String?
  createdAt   DateTime @default(now())

  actor       User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([createdAt])
}
